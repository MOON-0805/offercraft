[project]
requires = [ "python-3.12" ]
template = "vite"
version = "legacy"
appliedPatches = [ "vite/replace-npx-with-pnpm@0.0.13" ]

[dev]
build = [ "bash", "./scripts/prepare.sh" ]
run = [ "bash", "./scripts/dev.sh" ]

[deploy]
build = [ "bash", "./scripts/build.sh" ]
run = [ "bash", "./scripts/start.sh" ]
